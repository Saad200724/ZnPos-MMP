{
  "include": ["."],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "strict": true,
    "strictFunctionTypes": false,
    "noImplicitOverride": false,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  }
}
